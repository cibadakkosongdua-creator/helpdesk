# Telegram Bot Configuration (untuk notifikasi ke grup Telegram)
# Ikuti langkah di lib/helpdesk/telegram-service.ts untuk setup

# Token dari @BotFather (setelah buat bot baru)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID grup/channel (angka negatif, contoh: -1001234567890)
TELEGRAM_CHAT_ID=your_chat_id_here

# URL situs Anda (untuk link di notifikasi)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend Email Configuration (untuk notifikasi email)
# Daftar di https://resend.com dan buat API Key

# API Key dari Resend Dashboard
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email admin untuk terima notifikasi tiket baru (bisa email apapun)
ADMIN_EMAIL=admin@sdn02cibadak.sch.id

# URL aplikasi (untuk link di email)
NEXT_PUBLIC_APP_URL=https://helpdesk.sdn02cibadak.sch.id
